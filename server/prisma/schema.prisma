// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── Auth tables (required by NextAuth Prisma adapter) ───────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core user model ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed — null for OAuth users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  ownedWorkspaces   Workspace[]      @relation("WorkspaceOwner")
  memberships       WorkspaceMember[]
  assignedTasks     Task[]           @relation("TaskAssignee")
  createdTasks      Task[]           @relation("TaskCreator")
  messages          Message[]
  codeFiles         CodeFile[]       @relation("FileCreator")
  fileEdits         FileEdit[]
}

// ─── Workspace (top-level container for a project) ───────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique  // URL-safe identifier e.g. "my-project"
  description String?
  color       String   @default("#6366f1") // accent color for UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String

  // Relations
  owner    User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  WorkspaceMember[]
  columns  Column[]
  tasks    Task[]
  messages Message[]
  files    CodeFile[]

  @@index([ownerId])
  @@index([slug])
}

// ─── Workspace membership (many-to-many with roles) ──────────────────────────

model WorkspaceMember {
  id          String          @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole   @default(MEMBER)
  joinedAt    DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])  // one membership per user per workspace
  @@index([workspaceId])
  @@index([userId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Kanban columns ───────────────────────────────────────────────────────────

model Column {
  id          String   @id @default(cuid())
  name        String
  order       Int      // position in the board (0, 1, 2...)
  color       String   @default("#e2e8f0")
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([workspaceId])
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  order       Int          // position within a column
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Foreign keys
  workspaceId String
  columnId    String
  creatorId   String
  assigneeId  String?

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column    Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  creator   User      @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee  User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  labels    TaskLabel[]

  @@index([workspaceId])
  @@index([columnId])
  @@index([assigneeId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TaskLabel {
  id     String @id @default(cuid())
  name   String
  color  String
  taskId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─── Chat messages ────────────────────────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  content     String   @db.Text
  createdAt   DateTime @default(now())
  editedAt    DateTime?
  workspaceId String
  authorId    String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
}

// ─── Code files ───────────────────────────────────────────────────────────────

model CodeFile {
  id          String   @id @default(cuid())
  name        String
  path        String   // e.g. "src/components/Button.tsx"
  content     String   @db.Text @default("")
  language    String   @default("typescript")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspaceId String
  creatorId   String

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User       @relation("FileCreator", fields: [creatorId], references: [id])
  edits     FileEdit[]

  @@unique([workspaceId, path])  // no duplicate paths in same workspace
  @@index([workspaceId])
}

// ─── File edit history (for Phase 4 — stored for audit trail) ────────────────

model FileEdit {
  id        String   @id @default(cuid())
  fileId    String
  userId    String
  diff      String   @db.Text  // stores the change
  createdAt DateTime @default(now())

  file CodeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
}